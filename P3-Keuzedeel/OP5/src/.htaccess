RewriteEngine On

# Voorkom dat de regel loopt als het een echte map is
RewriteCond %{REQUEST_FILENAME} !-d
# Controleer of het bestand met .html erachter wel bestaat
RewriteCond %{REQUEST_FILENAME}.html -f
# Toon de HTML-pagina zonder de extensie te tonen
RewriteRule ^([^\.]+)$ $1.html [NC,L]


ErrorDocument 404 /error.html

DirectoryIndex about.html index.html
